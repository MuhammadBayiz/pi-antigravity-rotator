# Phone-side secrets/config for the agy wrapper. Install at
# $PI_ROTATOR_DIR/vps.env (default ~/.pi-antigravity-rotator/vps.env), chmod 600.
# NEVER commit the real file.

# One of the rotator's PI_ROTATOR_CLIENT_KEYS. Presented on the CONNECT as
# HTTPS_PROXY=http://<key>@127.0.0.1:<port> so the forward proxy is not open.
ROTATOR_CLIENT_KEY=REPLACE_ME

# Cloudflare Access service token (for `cloudflared access tcp`). Once you enable
# an Access policy on the TCP hostname, this is what authenticates the tunnel.
CF_ACCESS_CLIENT_ID=REPLACE_ME.access
CF_ACCESS_CLIENT_SECRET=REPLACE_ME

# The Cloudflare TCP public hostname mapped to tcp://127.0.0.1:51200 on the VPS.
ROTATOR_PROXY_HOSTNAME=rotator-proxy.example.com

# Local port the tunnel listens on (agy's HTTPS_PROXY target).
ROTATOR_LOCAL_PORT=51299
