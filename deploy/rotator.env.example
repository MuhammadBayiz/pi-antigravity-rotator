# Copy to /home/kizoo/.pi-antigravity-rotator/rotator.env and `chmod 600` it.
# Referenced by pi-antigravity-rotator.service as EnvironmentFile.
#
# Generate strong values, e.g.:  openssl rand -hex 32
#
# One client key per consumer (comma-separated) so a leaked key can be revoked
# without disrupting the others. The CI Action uses one of these as x-api-key.
PI_ROTATOR_CLIENT_KEYS=ci-key-REPLACE_ME,spare-key-REPLACE_ME

# Guards the dashboard + /api/* management routes (accepted as a superset on the
# serving routes too). Keep it distinct from the client keys.
PI_ROTATOR_ADMIN_TOKEN=admin-REPLACE_ME
